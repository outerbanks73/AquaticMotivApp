# Optional live Shopify Storefront API data. The app falls back to src/data/shopify-seed.json when unset.
SHOPIFY_STORE_DOMAIN=aquaticmotiv.myshopify.com
SHOPIFY_STOREFRONT_TOKEN=

# Production builds can pin /_next/* assets to the standalone origin while
# public canonical URLs point at the Shopify app proxy. Leave unset in local development.
ASSET_ORIGIN=

# Optional Admin API credentials for scripts/lib/shopify-admin.mjs based sync scripts.
SHOPIFY_APP_CLIENT_ID=
SHOPIFY_APP_CLIENT_SECRET=
